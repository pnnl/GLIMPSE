{
    "name": "glimpse",
    "productName": "GLIMPSE",
    "description": "GLIMPSE",
    "version": "0.7.0",
    "author": {
        "name": "Armando Mendoza Sanchez",
        "email": "mendozasanchez166@pnnl.gov"
    },
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "cd local-server && python3 server.py || python server.py",
        "dev:frontend": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "start": "concurrently \"npm run dev:backend\" \"vite preview\"",
        "electron:dev": "concurrently -k \"npm run dev:backend\" \"vite --strictPort --host 127.0.0.1\" \"npm run electron:start\"",
        "electron:start": "wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 electron .",
        "build:server": "cd local-server && pyinstaller server.spec --noconfirm",
        "dist": "npm run build && npm run build:server && electron-builder",
        "dist:win": "npm run build && npm run build:server && electron-builder --win",
        "dist:mac": "npm run build && npm run build:server && electron-builder --mac",
        "dist:linux": "npm run build && npm run build:server && electron-builder --linux"
    },
    "dependencies": {
        "@ant-design/icons": "^6.1.0",
        "@react-sigma/core": "^5.0.6",
        "@react-sigma/layout-circlepack": "^5.0.6",
        "@react-sigma/layout-core": "^5.0.6",
        "@react-sigma/layout-force": "^5.0.6",
        "@react-sigma/layout-forceatlas2": "^5.0.6",
        "@sigma/edge-curve": "^3.1.0",
        "@sigma/export-image": "^3.0.0",
        "@sigma/layer-webgl": "^3.0.0",
        "@sigma/node-border": "^3.0.0",
        "@sigma/node-image": "^3.0.0",
        "antd": "^6.1.0",
        "axios": "^1.13.2",
        "echarts-for-react": "^3.0.6",
        "graphology": "^0.26.0",
        "graphology-communities-louvain": "^2.0.2",
        "graphology-layout-force": "^0.2.4",
        "graphology-layout-forceatlas2": "^0.10.1",
        "graphology-metrics": "^2.4.0",
        "iwanthue": "^2.0.0",
        "mermaid": "^11.14.0",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-icons": "^5.5.0",
        "react-router": "^7.9.3",
        "sigma": "^3.0.2",
        "socket.io-client": "^4.8.3",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.16",
        "@types/react-dom": "^19.1.9",
        "@vitejs/plugin-react": "^5.0.4",
        "concurrently": "^10.0.3",
        "cross-env": "^10.1.0",
        "electron": "^42.4.0",
        "electron-builder": "^26.15.2",
        "globals": "^16.4.0",
        "vite": "^8.0.16",
        "wait-on": "^9.0.10"
    }
}
